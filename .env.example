# TheSlowBrain — example environment file
#
# Copy this file to `.env` and fill in only what you need. EVERY value here is
# OPTIONAL: with an empty .env the project still imports, runs its test suite,
# and produces shadow reports. The keys below switch on optional integrations.
#
# `.env` is gitignored and is never committed. Never put real secrets in this
# example file. The loader uses os.environ.setdefault, so it will not override
# variables already set in your shell.

# ---------------------------------------------------------------------------
# Imported evidence (local only)
# ---------------------------------------------------------------------------
# Absolute path to a local dataset whose raw data/ledgers are imported as
# evidence. Only needed if you run the legacy import or the full (non-demo)
# cycle on your own dataset.
SLOWBRAIN_LEGACY_STOCK_PROJECT=

# ---------------------------------------------------------------------------
# Market-data vendors (read-only price/benchmark/liquidity evidence)
# The provider chain is Alpha Vantage -> Finnhub -> Yahoo (Yahoo needs no key).
# ---------------------------------------------------------------------------
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
# Master switch for market-data HTTP. Default true. Set false for fully offline,
# deterministic runs (tests and incident control).
SLOWBRAIN_MARKET_DATA_ENABLED=true
# Optional local cache directory for raw vendor responses.
SLOWBRAIN_MARKET_DATA_CACHE_DIR=
# Optional fixed USD->GBP rate; if unset, an as-of Yahoo FX lookup is used.
SLOWBRAIN_MARKET_DATA_USD_GBP_RATE=
# Benchmark symbol for alpha/beta. Default SPY.
SLOWBRAIN_MARKET_DATA_BENCHMARK_SYMBOL=SPY

# ---------------------------------------------------------------------------
# Learned-gate promotion (the network earns influence on PROFIT, not by default)
# The gate climbs a ladder by beating the rubric on after-cost, out-of-sample return
# (deflated Sharpe + PBO guarded) AND clearing calibration/anchor checks for this many
# consecutive runs:
#   shadow -> confirm_only (veto) -> co_decide (veto + upgrade) -> gate_primary
# At gate_primary the NN proposes decisions and the rubric becomes a guardrail. It
# demotes if its edge decays. Everything stays paper/shadow; promotion never unblocks
# live execution.
# ---------------------------------------------------------------------------
# Consecutive qualifying runs required to advance one stage (default 10).
SLOWBRAIN_GATING_REQUIRED_STREAK=10
# Operator override / kill switch: force a stage regardless of earned state.
# One of: shadow | confirm_only | co_decide | gate_primary. Leave unset for normal
# earned behaviour (recommended).
SLOWBRAIN_GATING_STAGE_OVERRIDE=

# Gate training target labels. Default keeps the existing absolute return thresholds.
# Use cross_sectional_rank only for explicit PR12 experiments.
SLOWBRAIN_GATING_LABEL_MODE=absolute_return

# ---------------------------------------------------------------------------
# Point-in-time enrichment export (off by default)
# ---------------------------------------------------------------------------
# Optional local JSONL/CSV export of vendor fundamentals/news/sentiment records.
# Records are joined only when available_date <= signal_date.
SLOWBRAIN_PIT_ENRICHMENT_ENABLED=false
SLOWBRAIN_PIT_ENRICHMENT_PATH=

# ---------------------------------------------------------------------------
# OpenAI LLM judge (research / evaluation only — degrades to "unknown" if unset)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=

# ---------------------------------------------------------------------------
# Trading 212 execution gate (live order submission is OFF by default)
# Live submission additionally requires a fresh ready preview, --execute, a
# matching approval token, valid broker health, and duplicate-ledger clearance.
# Leave TRADING_LIVE_ENABLED=false unless you fully intend a manual live submit.
# ---------------------------------------------------------------------------
TRADING212_API_KEY=
TRADING212_API_SECRET=
TRADING212_ENV=demo
TRADING_LIVE_ENABLED=false
TRADING_REQUIRE_MANUAL_APPROVAL=true
TRADING_MAX_DAILY_ORDERS=
TRADING_MAX_ORDER_VALUE=

# ---------------------------------------------------------------------------
# Telegram brief delivery (dry-run by default; real send needs --send + creds)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=
