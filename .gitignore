# ---------------------------------------------------------------------------
# TheSlowBrain — public repository ignore rules
#
# This repository publishes only the finished product: source, tests, the
# packaged docs, and reproducible dependency metadata. Local development
# scaffolding, private data, secrets, and generated artefacts stay local.
# ---------------------------------------------------------------------------

# Secrets and environment
.env
.env.*
!.env.example

# Python / tooling caches and virtualenv
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coveragerc.clone

# Private data (imported evidence, vendor cache) — never published
data/*
!data/.gitkeep

# Generated reports and runtime state — regenerated by the workflow
reports/*
!reports/.gitkeep
state/*
!state/.gitkeep

# ---------------------------------------------------------------------------
# Local development scaffolding (kept on disk, not part of the public product)
# ---------------------------------------------------------------------------

# Agent / session workflow docs
AGENTS.md
CLAUDE.md
CODEX.md
START_HERE.md
SESSION_START.md
.claude/

# Project-management / build-process narrative
PROJECT_STATE.md
SPRINTS.md
PROJECT_SYNC_LOG.md
PROJECT_INIT.md
ADOPT_TEMPLATE.md
PRODUCT.md
DESIGN.md

# Reviews and development history
360_review.md
reviews/
memory/

# Research preflights, completed-sprint archive, and the internal HTML
docs/research/
docs/archive/
docs/TheSlowBrain-source-of-truth.html

# Build-process tooling (closeout grader + high-risk preflight gate)
src/slowbrain/quality_review/
scripts/build_closeout_review.py
scripts/start_high_risk_slice.py
scripts/validate_research_preflight.py
tests/test_quality_review.py
